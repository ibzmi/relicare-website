---
// src/pages/terms.astro
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Terms of Use | Relicare</title>
  <meta name="description" content="Terms governing your use of relicareuk.com, operated by Relicare Ltd." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:        #0f1a14;
      --ink-muted:  #4a5c50;
      --ink-faint:  #8a9e90;
      --paper:      #f5f2eb;
      --paper-warm: #ede9df;
      --green:      #1a6640;
      --green-light:#2d8a58;
      --green-pale: #e8f2ec;
      --accent:     #c8602a;
      --border:     #d4cec2;
      --white:      #ffffff;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--paper);
      color: var(--ink);
      font-size: 16px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: rgba(245,242,235,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      font-family: 'DM Serif Display', serif;
      font-size: 1.5rem;
      color: var(--green);
      text-decoration: none;
      letter-spacing: -0.02em;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }
    .nav-links a {
      text-decoration: none;
      color: var(--ink-muted);
      font-size: 0.9rem;
      font-weight: 500;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--green); }
    .nav-cta {
      background: var(--green) !important;
      color: var(--white) !important;
      padding: 0.5rem 1.2rem;
      border-radius: 4px;
      font-weight: 600 !important;
      transition: background 0.2s !important;
    }
    .nav-cta:hover { background: var(--green-light) !important; }

    /* ARTICLE LAYOUT */
    .article-wrap {
      max-width: 760px;
      margin: 0 auto;
      padding: 120px 2rem 5rem;
    }
    .article-wrap h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: var(--ink);
      margin-bottom: 0.75rem;
    }
    .article-intro {
      font-size: 1rem;
      color: var(--ink-muted);
      line-height: 1.7;
      font-weight: 300;
      margin-bottom: 0.5rem;
    }
    .article-updated {
      font-size: 0.82rem;
      color: var(--ink-faint);
      margin-bottom: 2.5rem;
    }
    .article-wrap h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.3rem, 2.5vw, 1.7rem);
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
    }
    .article-wrap p {
      font-size: 0.9375rem;
      color: var(--ink-muted);
      line-height: 1.7;
      margin-bottom: 1rem;
      font-weight: 300;
    }
    .article-wrap p strong { color: var(--ink); font-weight: 600; }
    .article-wrap ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin: 0.75rem 0 1rem;
    }
    .article-wrap ul li {
      position: relative;
      padding-left: 1.25rem;
      font-size: 0.9rem;
      color: var(--ink-muted);
      line-height: 1.6;
      font-weight: 300;
    }
    .article-wrap ul li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 10px;
      width: 6px;
      height: 6px;
      background: var(--green);
      border-radius: 50%;
    }
    .article-wrap ul li strong { color: var(--ink); font-weight: 600; }
    .article-wrap a { color: var(--green); font-weight: 500; text-decoration: none; }
    .article-wrap a:hover { text-decoration: underline; }

    /* FOOTER */
    footer { background: var(--ink); border-top: 1px solid rgba(255,255,255,0.06); padding: 2rem; text-align: center; }
    footer p { font-size: 0.8rem; color: #4a5c50; line-height: 1.8; }
    footer a { color: #6daa84; text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .nav-links { display: none; }
    }
    @media (max-width: 600px) {
      .article-wrap { padding: 100px 1.25rem 3.5rem; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="/" class="nav-logo">Relicare</a>
  <ul class="nav-links">
    <li><a href="/#how-it-works">How it works</a></li>
    <li><a href="/#packages">Pricing</a></li>
    <li><a href="/explainer">What is EPR?</a></li>
    <li><a href="/eligibility-check" class="nav-cta">Check eligibility</a></li>
  </ul>
</nav>
<main>

<div class="article-wrap">

